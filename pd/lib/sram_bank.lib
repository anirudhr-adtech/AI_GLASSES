      direction : input;
      capacitance : 0.01;
      timing() {
        related_pin : "clk";
        timing_type : setup_rising;
        rise_constraint(constraint_2x2) {
          values("0.5, 0.5", \
                 "0.5, 0.5");
        }
        fall_constraint(constraint_2x2) {
          values("0.5, 0.5", \
                 "0.5, 0.5");
        }
      }
      timing() {
        related_pin : "clk";
        timing_type : hold_rising;
        rise_constraint(constraint_2x2) {
          values("0.2, 0.2", \
                 "0.2, 0.2");
        }
        fall_constraint(constraint_2x2) {
